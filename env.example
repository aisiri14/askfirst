# ──────────────────────────────────────────────────────────────────
#  AskFirst — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  Never commit your real `.env` to version control.
# ──────────────────────────────────────────────────────────────────

# ── Primary LLM: Groq ──────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=

# Model to use on Groq (default: llama3-8b-8192)
# Other options: llama3-70b-8192 | mixtral-8x7b-32768 | gemma-7b-it
GROQ_MODEL=llama3-8b-8192

# ── Fallback LLM: Gemini ───────────────────────────────────────────
# Get your key at https://aistudio.google.com
GEMINI_API_KEY=

# Model to use on Gemini (default: gemini-1.5-flash)
# Other options: gemini-1.5-pro | gemini-1.0-pro
GEMINI_MODEL=gemini-1.5-flash

# ── Database ───────────────────────────────────────────────────────
# SQLite file path (relative to project root). No changes needed unless
# you want to store the DB elsewhere.
# DATABASE_URL=sqlite:///./askfirst.db

# ── Backend server ─────────────────────────────────────────────────
# These are used when you start the server manually.
# HOST=0.0.0.0
# PORT=8000
